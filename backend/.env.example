# Security
SECRET_KEY=change-this-in-production

# Database
# Leave DATABASE_URL empty for SQLite fallback during local development.
# Example PostgreSQL URL:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/diabetes_app
USE_SQLITE_FALLBACK=true

# Optional explicit SQLite path if you want:
# DATABASE_URL=sqlite:///./diabetes_app.db
